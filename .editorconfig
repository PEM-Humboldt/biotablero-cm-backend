# top-most EditorConfig file

root = true

# C# files

[*.cs]

# General rules

charset = utf-8-bom
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
end_of_line = crlf

# Spacing and indentation

csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = flush_left
csharp_indent_block_contents = true

# Brace style

csharp_new_line_before_open_brace = all
csharp_new_line_between_query_expression_clauses = true

# Usings

dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true

# Namespaces

csharp_style_namespace_declarations = file_scoped:error

# this. on members

dotnet_style_qualification_for_field = false:error
dotnet_style_qualification_for_property = false:error
dotnet_style_qualification_for_method = false:error
dotnet_style_qualification_for_event = false:error

# var or explicit type

dotnet_style_require_var_for_built_in_types = false:error
dotnet_style_require_var_when_type_is_apparent = true:error
dotnet_style_require_var_elsewhere = true:error

# Lambda expressions

csharp_style_expression_bodied_methods = true:error
csharp_style_expression_bodied_properties = true:error

# Null checks and patterns

csharp_style_prefer_pattern_matching = true:error
csharp_style_prefer_switch_expression = true:error
csharp_style_pattern_local_over_anonymous_function = true:error

# Others

csharp_style_var_elsewhere = true:error
csharp_style_deconstructed_variable_declaration = true:error

# ------------------- #
# Custom dotnet rules #
# ------------------- #

# Namespace does not match folder structure
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/ide0130
dotnet_diagnostic.ide0130.severity = warning

# Declare types in namespaces
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/quality-rules/ca1050
dotnet_diagnostic.ca1050.severity = warning

# Naming rule violation: These words must begin with upper case characters
# https://learn.microsoft.com/en-us/dotnet/fundamentals/code-analysis/style-rules/naming-rules
dotnet_diagnostic.ide1006.severity = warning

# --------------------- #
# Custom StyleCop rules #
# --------------------- #

# XML comment analysis is disabled due to project configuration
# https://github.com/DotNetAnalyzers/StyleCopAnalyzers/blob/master/documentation/SA0001.md
dotnet_diagnostic.SA0001.severity = none

# A C# code file is missing a standard file header.
# https://github.com/DotNetAnalyzers/StyleCopAnalyzers/blob/master/documentation/SA1633.md
dotnet_diagnostic.SA1633.severity = none

# Documentation text should end with a period
# https://github.com/DotNetAnalyzers/StyleCopAnalyzers/blob/master/documentation/SA1629.md
dotnet_diagnostic.SA1629.severity = none

# Two or more attributes appeared within the same set of square brackets.
# https://github.com/DotNetAnalyzers/StyleCopAnalyzers/blob/master/documentation/SA1133.md
dotnet_diagnostic.SA1133.severity = none

# A call to an instance member of the local class or a base class is not prefixed with 'this.', within a C# code file
# https://github.com/DotNetAnalyzers/StyleCopAnalyzers/blob/master/documentation/SA1101.md
dotnet_diagnostic.SA1101.severity = none
